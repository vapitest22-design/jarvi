<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Cosmic Blueprint — Your Life's Sacred Map</title>
<link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@400;700;900&family=Cinzel:wght@400;500;600&family=Crimson+Pro:ital,wght@0,300;0,400;1,300;1,400&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<style>
  :root {
    --gold: #c9a84c;
    --gold-light: #e8d48b;
    --gold-dim: #8a6f2e;
    --deep: #05040f;
    --deep2: #0c0a1e;
    --deep3: #110e2a;
    --violet: #2d1b69;
    --violet-light: #4a2fa3;
    --text: #e8e0d0;
    --text-dim: #9a8f7e;
    --accent: #7b5ea7;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--deep);
    color: var(--text);
    font-family: 'Crimson Pro', Georgia, serif;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* STARFIELD */
  #stars-canvas {
    position: fixed; top: 0; left: 0; width: 100%; height: 100%;
    pointer-events: none; z-index: 0; opacity: 0.6;
  }

  /* SACRED GEOMETRY BG */
  .sacred-bg {
    position: fixed; top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 900px; height: 900px;
    pointer-events: none; z-index: 0; opacity: 0.04;
    animation: slowRotate 120s linear infinite;
  }
  @keyframes slowRotate { to { transform: translate(-50%, -50%) rotate(360deg); } }

  .container {
    position: relative; z-index: 1;
    max-width: 860px; margin: 0 auto;
    padding: 60px 24px 100px;
  }

  /* HEADER */
  .header {
    text-align: center;
    margin-bottom: 60px;
    animation: fadeDown 1.2s ease both;
  }
  @keyframes fadeDown { from { opacity:0; transform:translateY(-30px); } to { opacity:1; transform:none; } }

  .header-sigil {
    width: 80px; height: 80px;
    margin: 0 auto 24px;
    animation: pulse 4s ease-in-out infinite;
  }
  @keyframes pulse { 0%,100%{opacity:.7;transform:scale(1)} 50%{opacity:1;transform:scale(1.08)} }

  .header h1 {
    font-family: 'Cinzel Decorative', serif;
    font-size: clamp(1.8rem, 5vw, 3.2rem);
    font-weight: 900;
    background: linear-gradient(135deg, var(--gold-light) 0%, var(--gold) 40%, var(--gold-dim) 100%);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    letter-spacing: 0.05em;
    line-height: 1.2;
    margin-bottom: 12px;
  }

  .header p {
    font-size: 1.1rem; color: var(--text-dim);
    font-style: italic; letter-spacing: 0.08em;
    font-family: 'Cinzel', serif; font-weight: 400;
  }

  .divider {
    display: flex; align-items: center; gap: 16px;
    margin: 28px auto; max-width: 400px;
  }
  .divider-line { flex:1; height:1px; background: linear-gradient(to right, transparent, var(--gold-dim), transparent); }
  .divider-gem { color: var(--gold); font-size: 1rem; }

  /* FORM CARD */
  .form-card {
    background: linear-gradient(145deg, rgba(13,11,30,0.95), rgba(20,16,48,0.9));
    border: 1px solid rgba(201,168,76,0.25);
    border-radius: 4px;
    padding: 48px 40px;
    box-shadow: 0 0 80px rgba(74,47,163,0.15), 0 0 0 1px rgba(201,168,76,0.08) inset;
    animation: fadeUp 1.4s ease both 0.3s;
  }
  @keyframes fadeUp { from { opacity:0; transform:translateY(40px); } to { opacity:1; transform:none; } }

  .form-section-title {
    font-family: 'Cinzel', serif;
    font-size: 0.72rem; letter-spacing: 0.25em; text-transform: uppercase;
    color: var(--gold); margin-bottom: 28px;
    display: flex; align-items: center; gap: 12px;
  }
  .form-section-title::after { content:''; flex:1; height:1px; background: rgba(201,168,76,0.2); }

  .form-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 24px;
    margin-bottom: 24px;
  }
  @media(max-width:600px) { .form-grid { grid-template-columns: 1fr; } .form-card { padding: 32px 20px; } }

  .field { display: flex; flex-direction: column; gap: 8px; }
  .field.full { grid-column: 1 / -1; }

  label {
    font-family: 'Cinzel', serif;
    font-size: 0.68rem; letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--gold-dim);
  }

  input {
    background: rgba(5,4,15,0.6);
    border: 1px solid rgba(201,168,76,0.2);
    border-radius: 2px;
    color: var(--text);
    font-family: 'Crimson Pro', serif;
    font-size: 1.05rem;
    padding: 12px 16px;
    transition: border-color 0.3s, box-shadow 0.3s;
    outline: none;
    width: 100%;
  }
  input:focus {
    border-color: rgba(201,168,76,0.6);
    box-shadow: 0 0 20px rgba(201,168,76,0.08);
  }
  input::placeholder { color: rgba(154,143,126,0.4); font-style: italic; }
  input[type="date"]::-webkit-calendar-picker-indicator { filter: invert(0.6) sepia(1) saturate(0.5); }

  /* SUBMIT BUTTON */
  .btn-reveal {
    width: 100%; margin-top: 32px;
    background: transparent;
    border: 1px solid var(--gold);
    color: var(--gold-light);
    font-family: 'Cinzel', serif;
    font-size: 0.85rem; letter-spacing: 0.25em; text-transform: uppercase;
    padding: 18px 32px;
    cursor: pointer;
    position: relative; overflow: hidden;
    transition: color 0.4s;
    border-radius: 2px;
  }
  .btn-reveal::before {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(135deg, var(--gold-dim), var(--gold));
    transform: scaleX(0); transform-origin: left;
    transition: transform 0.4s cubic-bezier(0.4,0,0.2,1);
    z-index: 0;
  }
  .btn-reveal:hover { color: var(--deep); }
  .btn-reveal:hover::before { transform: scaleX(1); }
  .btn-reveal span { position: relative; z-index: 1; }
  .btn-reveal:disabled { opacity: 0.4; cursor: not-allowed; }

  /* LOADING */
  .loading-state {
    display: none; text-align: center; padding: 60px 0;
  }
  .loading-state.active { display: block; }
  .loading-mandala {
    width: 80px; height: 80px;
    border: 2px solid rgba(201,168,76,0.1);
    border-top: 2px solid var(--gold);
    border-radius: 50%;
    margin: 0 auto 24px;
    animation: spin 1.5s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
  .loading-text {
    font-family: 'Cinzel', serif; font-size: 0.8rem;
    letter-spacing: 0.2em; color: var(--text-dim);
    animation: flicker 2s ease-in-out infinite;
  }
  @keyframes flicker { 0%,100%{opacity:.5} 50%{opacity:1} }

  /* RESULT */
  .result-section { display: none; margin-top: 48px; }
  .result-section.active { display: block; animation: fadeUp 0.8s ease both; }

  .result-header {
    text-align: center; margin-bottom: 36px;
  }
  .result-name {
    font-family: 'Cinzel Decorative', serif;
    font-size: clamp(1.4rem, 3.5vw, 2.2rem);
    background: linear-gradient(135deg, var(--gold-light), var(--gold));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    margin-bottom: 6px;
  }
  .result-sub {
    font-size: 0.9rem; color: var(--text-dim);
    font-family: 'Cinzel', serif; letter-spacing: 0.12em;
  }

  .section-block {
    background: linear-gradient(145deg, rgba(8,6,20,0.8), rgba(17,14,42,0.7));
    border: 1px solid rgba(201,168,76,0.15);
    border-radius: 2px;
    padding: 28px 32px;
    margin-bottom: 20px;
    position: relative;
    overflow: hidden;
  }
  .section-block::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--gold-dim), transparent);
  }

  .section-num {
    font-family: 'Cinzel', serif; font-size: 0.6rem;
    letter-spacing: 0.3em; color: var(--gold-dim);
    margin-bottom: 6px;
  }
  .section-title {
    font-family: 'Cinzel', serif; font-size: 1.05rem;
    color: var(--gold-light); margin-bottom: 14px;
    letter-spacing: 0.05em;
  }
  .section-body {
    font-size: 1rem; line-height: 1.8;
    color: rgba(232,224,208,0.85);
  }

  /* NUMBERS ROW */
  .numbers-row {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(110px, 1fr));
    gap: 16px; margin-bottom: 32px;
  }
  .num-card {
    text-align: center;
    background: rgba(5,4,15,0.5);
    border: 1px solid rgba(201,168,76,0.2);
    border-radius: 2px; padding: 20px 12px;
  }
  .num-card-val {
    font-family: 'Cinzel Decorative', serif; font-size: 2rem;
    color: var(--gold); line-height: 1;
    margin-bottom: 6px;
  }
  .num-card-label {
    font-family: 'Cinzel', serif; font-size: 0.6rem;
    letter-spacing: 0.15em; color: var(--text-dim);
    text-transform: uppercase;
  }

  /* PDF BUTTON */
  .btn-pdf {
    display: flex; align-items: center; justify-content: center; gap: 10px;
    width: 100%; margin-top: 40px;
    background: linear-gradient(135deg, var(--gold-dim), var(--gold));
    border: none;
    color: var(--deep);
    font-family: 'Cinzel', serif;
    font-size: 0.85rem; letter-spacing: 0.2em; text-transform: uppercase;
    padding: 20px 32px;
    cursor: pointer;
    border-radius: 2px;
    font-weight: 600;
    transition: opacity 0.3s, transform 0.2s;
    box-shadow: 0 8px 40px rgba(201,168,76,0.25);
  }
  .btn-pdf:hover { opacity: 0.9; transform: translateY(-2px); }

  /* PROGRESS BAR */
  .progress-bar {
    height: 2px;
    background: rgba(201,168,76,0.1);
    border-radius: 2px;
    margin-top: 12px;
    overflow: hidden;
  }
  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--gold-dim), var(--gold));
    width: 0%;
    transition: width 0.5s ease;
    border-radius: 2px;
  }

  .loading-steps {
    margin-top: 16px;
    font-size: 0.85rem; color: var(--text-dim);
    font-style: italic;
  }
</style>
</head>
<body>

<canvas id="stars-canvas"></canvas>

<svg class="sacred-bg" viewBox="0 0 800 800" xmlns="http://www.w3.org/2000/svg">
  <circle cx="400" cy="400" r="380" fill="none" stroke="#c9a84c" stroke-width="0.5"/>
  <circle cx="400" cy="400" r="300" fill="none" stroke="#c9a84c" stroke-width="0.5"/>
  <circle cx="400" cy="400" r="220" fill="none" stroke="#c9a84c" stroke-width="0.5"/>
  <polygon points="400,50 720,600 80,600" fill="none" stroke="#c9a84c" stroke-width="0.5"/>
  <polygon points="400,750 80,200 720,200" fill="none" stroke="#c9a84c" stroke-width="0.5"/>
  <circle cx="400" cy="400" r="150" fill="none" stroke="#c9a84c" stroke-width="0.3"/>
  <line x1="400" y1="20" x2="400" y2="780" stroke="#c9a84c" stroke-width="0.2"/>
  <line x1="20" y1="400" x2="780" y2="400" stroke="#c9a84c" stroke-width="0.2"/>
  <line x1="70" y1="70" x2="730" y2="730" stroke="#c9a84c" stroke-width="0.2"/>
  <line x1="730" y1="70" x2="70" y2="730" stroke="#c9a84c" stroke-width="0.2"/>
</svg>

<div class="container">

  <!-- HEADER -->
  <header class="header">
    <svg class="header-sigil" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
      <circle cx="50" cy="50" r="46" fill="none" stroke="#c9a84c" stroke-width="1.5"/>
      <polygon points="50,8 90,78 10,78" fill="none" stroke="#c9a84c" stroke-width="1.5"/>
      <polygon points="50,92 10,22 90,22" fill="none" stroke="#c9a84c" stroke-width="1.5"/>
      <circle cx="50" cy="50" r="12" fill="none" stroke="#c9a84c" stroke-width="1"/>
      <circle cx="50" cy="50" r="3" fill="#c9a84c"/>
    </svg>
    <h1>Cosmic Blueprint</h1>
    <p>Your Sacred Life Map Through the Ancient Numbers</p>
    <div class="divider">
      <div class="divider-line"></div>
      <div class="divider-gem">✦</div>
      <div class="divider-line"></div>
    </div>
    <p style="font-size:0.95rem; max-width:520px; margin:0 auto; line-height:1.7; color:rgba(154,143,126,0.7); font-family:'Crimson Pro',serif;">
      Enter the coordinates of your birth into the cosmic record. The universe will reveal your life's sacred blueprint — your purpose, destiny, challenges, and hidden gifts.
    </p>
  </header>

  <!-- FORM -->
  <div class="form-card">
    <div class="form-section-title">Your Birth Coordinates</div>
    <form id="blueprintForm">
      <div class="form-grid">
        <div class="field full">
          <label>Full Name at Birth</label>
          <input type="text" id="fullName" placeholder="As written on your birth certificate" required>
        </div>
        <div class="field">
          <label>Date of Birth</label>
          <input type="date" id="dob" required>
        </div>
        <div class="field">
          <label>Time of Birth</label>
          <input type="time" id="tob" required>
        </div>
        <div class="field full">
          <label>Place of Birth</label>
          <input type="text" id="pob" placeholder="City, Country" required>
        </div>
      </div>
      <button type="submit" class="btn-reveal" id="revealBtn">
        <span>✦ Reveal My Cosmic Blueprint ✦</span>
      </button>
      <div class="progress-bar"><div class="progress-fill" id="progressFill"></div></div>
    </form>
  </div>

  <!-- LOADING -->
  <div class="loading-state" id="loadingState">
    <div class="loading-mandala"></div>
    <div class="loading-text">Consulting the Cosmic Records...</div>
    <div class="loading-steps" id="loadingStep">Calculating your sacred numbers...</div>
  </div>

  <!-- RESULT -->
  <div class="result-section" id="resultSection">
    <div class="result-header">
      <div class="result-name" id="resultName"></div>
      <div class="result-sub" id="resultSub"></div>
      <div class="divider"><div class="divider-line"></div><div class="divider-gem">✦</div><div class="divider-line"></div></div>
    </div>

    <div class="numbers-row" id="numbersRow"></div>
    <div id="sectionsContainer"></div>

    <button class="btn-pdf" id="downloadPdf">
      ✦ Download Your 100-Page Life Blueprint PDF ✦
    </button>
  </div>

</div>

<script>
// ── STARS ──────────────────────────────────────────────
const canvas = document.getElementById('stars-canvas');
const ctx = canvas.getContext('2d');
let stars = [];
function initStars() {
  canvas.width = window.innerWidth;
  canvas.height = window.innerHeight;
  stars = Array.from({length: 200}, () => ({
    x: Math.random() * canvas.width,
    y: Math.random() * canvas.height,
    r: Math.random() * 1.2 + 0.2,
    a: Math.random(),
    speed: Math.random() * 0.005 + 0.002
  }));
}
function drawStars() {
  ctx.clearRect(0, 0, canvas.width, canvas.height);
  stars.forEach(s => {
    s.a += s.speed;
    const alpha = (Math.sin(s.a) + 1) / 2 * 0.8 + 0.1;
    ctx.beginPath();
    ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
    ctx.fillStyle = `rgba(201,168,76,${alpha})`;
    ctx.fill();
  });
  requestAnimationFrame(drawStars);
}
window.addEventListener('resize', initStars);
initStars(); drawStars();

// ── NUMEROLOGY ────────────────────────────────────────
function reduceNum(n) {
  while (n > 9 && n !== 11 && n !== 22 && n !== 33) {
    n = String(n).split('').reduce((a, d) => a + parseInt(d), 0);
  }
  return n;
}
function letterValue(c) {
  const v = c.toUpperCase().charCodeAt(0) - 64;
  return v > 0 && v <= 26 ? v : 0;
}
function calcLifePath(dob) {
  const parts = dob.split('-');
  const sum = [...parts.join('')].reduce((a, d) => a + parseInt(d), 0);
  return reduceNum(sum);
}
function calcDestiny(name) {
  const sum = [...name.replace(/[^a-zA-Z]/g,'')].reduce((a, c) => a + letterValue(c), 0);
  return reduceNum(sum);
}
function calcSoulUrge(name) {
  const vowels = name.toUpperCase().replace(/[^AEIOU]/g, '');
  const sum = [...vowels].reduce((a, c) => a + letterValue(c), 0);
  return reduceNum(sum);
}
function calcPersonality(name) {
  const consonants = name.toUpperCase().replace(/[^BCDFGHJKLMNPQRSTVWXYZ]/g, '');
  const sum = [...consonants].reduce((a, c) => a + letterValue(c), 0);
  return reduceNum(sum);
}
function calcBirthDay(dob) {
  return reduceNum(parseInt(dob.split('-')[2]));
}

// ── SECTIONS TO GENERATE ─────────────────────────────
const SECTIONS = [
  "Life Purpose & Soul Mission",
  "Career & Professional Destiny",
  "Love, Relationships & Twin Flames",
  "Financial Blueprint & Abundance Codes",
  "Health & Vitality Energy Map",
  "Family & Ancestral Karma",
  "Hidden Talents & Suppressed Gifts",
  "Life Challenges & Karmic Lessons",
  "Spiritual Path & Higher Calling",
  "Past Life Influences",
  "Childhood Wounds & Healing Path",
  "Friendship & Social Energy",
  "Personal Year Forecast",
  "Pinnacle Cycles & Life Phases",
  "Shadow Self & Integration",
  "Communication Style & Expression",
  "Leadership Potential",
  "Creative Power & Artistic Soul",
  "Travel Destiny & Sacred Places",
  "Death, Rebirth & Transformation Cycles"
];

let fullBlueprintData = {};

// ── FORM SUBMIT ───────────────────────────────────────
document.getElementById('blueprintForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const name = document.getElementById('fullName').value.trim();
  const dob = document.getElementById('dob').value;
  const tob = document.getElementById('tob').value;
  const pob = document.getElementById('pob').value.trim();

  const nums = {
    lifePath: calcLifePath(dob),
    destiny: calcDestiny(name),
    soulUrge: calcSoulUrge(name),
    personality: calcPersonality(name),
    birthDay: calcBirthDay(dob)
  };

  document.getElementById('revealBtn').disabled = true;
  document.getElementById('loadingState').classList.add('active');
  document.getElementById('resultSection').classList.remove('active');

  const steps = [
    "Calculating your sacred numbers...",
    "Reading the Akashic Records...",
    "Mapping planetary alignments at birth...",
    "Decoding your soul contract...",
    "Unveiling your life blueprint...",
    "Channeling cosmic wisdom...",
    "Compiling your sacred report..."
  ];

  let stepIdx = 0;
  const stepInterval = setInterval(() => {
    stepIdx = (stepIdx + 1) % steps.length;
    document.getElementById('loadingStep').textContent = steps[stepIdx];
  }, 2500);

  const progress = document.getElementById('progressFill');

  try {
    const sections = {};
    for (let i = 0; i < SECTIONS.length; i++) {
      const sec = SECTIONS[i];
      progress.style.width = ((i + 1) / SECTIONS.length * 100) + '%';

      const prompt = `You are a master numerologist, astrologer, and life coach creating a comprehensive, deeply personal, and mystically insightful life blueprint. 

Person's Details:
- Full Name: ${name}
- Date of Birth: ${dob}
- Time of Birth: ${tob}
- Place of Birth: ${pob}
- Life Path Number: ${nums.lifePath}
- Destiny Number: ${nums.destiny}
- Soul Urge Number: ${nums.soulUrge}
- Personality Number: ${nums.personality}
- Birth Day Number: ${nums.birthDay}

Write a DETAILED, PROFOUND, and PERSONALIZED section titled "${sec}" for this specific person. 

Write 5-6 rich paragraphs (400-500 words total) that are:
- Deeply insightful and personalized using their name "${name}" multiple times
- Mystically poetic yet practically grounded
- Weaving together their numerology numbers meaningfully
- Including specific guidance, warnings, and opportunities
- Revealing hidden truths about this aspect of their life
- Using evocative, powerful language that feels sacred and true

Do NOT use headers, bullet points, or formatting — just flowing, profound prose that reads like a sacred oracle speaking directly to ${name}.`;

      const response = await fetch("https://api.anthropic.com/v1/messages", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          model: "claude-sonnet-4-20250514",
          max_tokens: 1000,
          messages: [{ role: "user", content: prompt }]
        })
      });
      const data = await response.json();
      sections[sec] = data.content?.[0]?.text || "The cosmic records are silent on this matter.";
    }

    clearInterval(stepInterval);
    document.getElementById('loadingState').classList.remove('active');

    // Store for PDF
    fullBlueprintData = { name, dob, tob, pob, nums, sections };

    // Render
    renderResult(name, dob, tob, pob, nums, sections);

  } catch(err) {
    clearInterval(stepInterval);
    document.getElementById('loadingState').classList.remove('active');
    document.getElementById('revealBtn').disabled = false;
    alert('The cosmic connection was interrupted. Please try again.');
    console.error(err);
  }
});

function renderResult(name, dob, tob, pob, nums, sections) {
  document.getElementById('resultName').textContent = name.toUpperCase();
  document.getElementById('resultSub').textContent = `Born ${dob} at ${tob} · ${pob}`;

  const numLabels = {
    lifePath: 'Life Path', destiny: 'Destiny', soulUrge: 'Soul Urge',
    personality: 'Personality', birthDay: 'Birth Day'
  };
  const numRow = document.getElementById('numbersRow');
  numRow.innerHTML = Object.entries(nums).map(([k,v]) =>
    `<div class="num-card">
      <div class="num-card-val">${v}</div>
      <div class="num-card-label">${numLabels[k]}</div>
    </div>`
  ).join('');

  const container = document.getElementById('sectionsContainer');
  container.innerHTML = Object.entries(sections).map(([title, body], i) =>
    `<div class="section-block">
      <div class="section-num">CHAPTER ${String(i+1).padStart(2,'0')}</div>
      <div class="section-title">${title}</div>
      <div class="section-body">${body}</div>
    </div>`
  ).join('');

  document.getElementById('resultSection').classList.add('active');
  document.getElementById('resultSection').scrollIntoView({ behavior: 'smooth', block: 'start' });

  document.getElementById('revealBtn').disabled = false;
  document.getElementById('progressFill').style.width = '100%';
}

// ── PDF GENERATION ────────────────────────────────────
document.getElementById('downloadPdf').addEventListener('click', generatePDF);

function generatePDF() {
  const { name, dob, tob, pob, nums, sections } = fullBlueprintData;
  const { jsPDF } = window.jspdf;
  const doc = new jsPDF({ orientation: 'portrait', unit: 'mm', format: 'a4' });

  const W = 210, H = 297;
  const MARGIN = 20;
  const TEXT_W = W - MARGIN * 2;

  // Color helpers
  const setGold = () => doc.setTextColor(180, 140, 55);
  const setGoldLight = () => doc.setTextColor(220, 190, 100);
  const setDark = () => doc.setTextColor(15, 12, 35);
  const setBody = () => doc.setTextColor(40, 35, 65);
  const setMuted = () => doc.setTextColor(120, 100, 140);

  function drawPageBg(isTitle = false) {
    // Deep background
    doc.setFillColor(8, 6, 20);
    doc.rect(0, 0, W, H, 'F');

    // Border
    doc.setDrawColor(100, 75, 30);
    doc.setLineWidth(0.3);
    doc.rect(8, 8, W - 16, H - 16, 'S');
    doc.setDrawColor(60, 45, 15);
    doc.setLineWidth(0.1);
    doc.rect(10, 10, W - 20, H - 20, 'S');
  }

  function addPageNumber(num) {
    doc.setFontSize(7);
    setMuted();
    doc.setFont('helvetica', 'italic');
    doc.text(`— ${num} —`, W / 2, H - 12, { align: 'center' });
    doc.setFontSize(6);
    doc.text('COSMIC BLUEPRINT  ·  SACRED LIFE REPORT', W / 2, H - 8, { align: 'center' });
  }

  function drawDivider(y) {
    doc.setDrawColor(120, 90, 30);
    doc.setLineWidth(0.2);
    doc.line(MARGIN + 20, y, W - MARGIN - 20, y);
  }

  // ── COVER PAGE ──
  drawPageBg(true);
  let y = 50;

  // Decorative circle
  doc.setDrawColor(120, 90, 30);
  doc.setLineWidth(0.4);
  doc.circle(W/2, 80, 35, 'S');
  doc.setLineWidth(0.2);
  doc.circle(W/2, 80, 28, 'S');
  doc.circle(W/2, 80, 20, 'S');

  // Triangle (Star of David simplified)
  const cx = W/2, cy = 80, r = 26;
  doc.setLineWidth(0.3);
  // Triangle up
  const t1 = [[cx, cy-r], [cx+r*0.866, cy+r*0.5], [cx-r*0.866, cy+r*0.5]];
  doc.lines([[t1[1][0]-t1[0][0], t1[1][1]-t1[0][1]], [t1[2][0]-t1[1][0], t1[2][1]-t1[1][1]], [t1[0][0]-t1[2][0], t1[0][1]-t1[2][1]]], t1[0][0], t1[0][1], [1,1], 'S');
  // Triangle down
  const t2 = [[cx, cy+r], [cx+r*0.866, cy-r*0.5], [cx-r*0.866, cy-r*0.5]];
  doc.lines([[t2[1][0]-t2[0][0], t2[1][1]-t2[0][1]], [t2[2][0]-t2[1][0], t2[2][1]-t2[1][1]], [t2[0][0]-t2[2][0], t2[0][1]-t2[2][1]]], t2[0][0], t2[0][1], [1,1], 'S');

  y = 130;
  doc.setFontSize(8);
  setGold();
  doc.setFont('helvetica', 'bold');
  doc.text('✦  THE SACRED NUMEROLOGY REPORT  ✦', W/2, y, { align: 'center' });

  y += 14;
  doc.setFontSize(22);
  setGoldLight();
  doc.text('COSMIC BLUEPRINT', W/2, y, { align: 'center' });

  y += 8;
  doc.setFontSize(11);
  setGold();
  doc.setFont('helvetica', 'italic');
  doc.text('Your Complete Life Map Through the Ancient Numbers', W/2, y, { align: 'center' });

  y += 18;
  drawDivider(y);

  y += 14;
  doc.setFontSize(16);
  setGoldLight();
  doc.setFont('helvetica', 'bold');
  doc.text(name.toUpperCase(), W/2, y, { align: 'center' });

  y += 8;
  doc.setFontSize(9);
  setMuted();
  doc.setFont('helvetica', 'normal');
  doc.text(`Born: ${dob}  ·  ${tob}  ·  ${pob}`, W/2, y, { align: 'center' });

  y += 20;
  drawDivider(y);

  // Numbers grid
  y += 14;
  doc.setFontSize(7);
  setGold();
  doc.setFont('helvetica', 'bold');
  doc.text('YOUR SACRED NUMBERS', W/2, y, { align: 'center' });

  y += 10;
  const numLabels = ['Life Path', 'Destiny', 'Soul Urge', 'Personality', 'Birth Day'];
  const numVals = [nums.lifePath, nums.destiny, nums.soulUrge, nums.personality, nums.birthDay];
  const cellW = 32, startX = (W - cellW * 5) / 2;

  numVals.forEach((v, i) => {
    const x = startX + i * cellW + cellW/2;
    doc.setFillColor(15, 12, 40);
    doc.setDrawColor(100, 75, 30);
    doc.setLineWidth(0.2);
    doc.rect(startX + i * cellW, y - 4, cellW - 2, 18, 'FD');
    doc.setFontSize(14);
    setGoldLight();
    doc.setFont('helvetica', 'bold');
    doc.text(String(v), x, y + 7, { align: 'center' });
    doc.setFontSize(5.5);
    setMuted();
    doc.setFont('helvetica', 'normal');
    doc.text(numLabels[i].toUpperCase(), x, y + 12, { align: 'center' });
  });

  y += 30;
  doc.setFontSize(7.5);
  setMuted();
  doc.setFont('helvetica', 'italic');
  const introText = `This document contains ${SECTIONS.length} chapters revealing the complete numerological blueprint of ${name}'s life. Each chapter has been channeled through the ancient wisdom of sacred numbers, planetary influences, and karmic records. Read with an open heart and receptive mind.`;
  const introLines = doc.splitTextToSize(introText, TEXT_W - 20);
  doc.text(introLines, W/2, y, { align: 'center' });

  y += introLines.length * 4 + 15;
  drawDivider(y);

  y += 10;
  doc.setFontSize(6.5);
  setGold();
  doc.setFont('helvetica', 'bold');
  doc.text('✦', W/2, y, { align: 'center' });

  addPageNumber(1);

  // ── TABLE OF CONTENTS ──
  doc.addPage();
  drawPageBg();
  y = 30;

  doc.setFontSize(7);
  setGold();
  doc.setFont('helvetica', 'bold');
  doc.text('TABLE OF CONTENTS', W/2, y, { align: 'center' });
  y += 4;
  drawDivider(y);
  y += 12;

  SECTIONS.forEach((title, i) => {
    if (y > H - 25) {
      addPageNumber(2);
      doc.addPage();
      drawPageBg();
      y = 30;
    }
    doc.setFontSize(8);
    setGoldLight();
    doc.setFont('helvetica', 'normal');
    doc.text(`${String(i+1).padStart(2,'0')}.`, MARGIN + 5, y);
    setBody();
    doc.setTextColor(180, 165, 200);
    doc.text(title, MARGIN + 16, y);
    doc.setFontSize(7);
    setMuted();
    y += 10;
  });

  addPageNumber(2);

  // ── CHAPTER PAGES ──
  let pageNum = 3;
  const sectionEntries = Object.entries(sections);

  for (let idx = 0; idx < sectionEntries.length; idx++) {
    const [title, body] = sectionEntries[idx];

    // Chapter title page
    doc.addPage();
    drawPageBg();

    // Decorative circles
    doc.setDrawColor(80, 60, 20);
    doc.setLineWidth(0.2);
    doc.circle(W/2, 85, 25, 'S');
    doc.circle(W/2, 85, 18, 'S');

    y = 65;
    doc.setFontSize(7);
    setMuted();
    doc.setFont('helvetica', 'bold');
    doc.text(`CHAPTER ${String(idx+1).padStart(2,'0')}`, W/2, y, { align: 'center' });

    y = 100;
    doc.setFontSize(13);
    setGoldLight();
    doc.setFont('helvetica', 'bold');
    const titleLines = doc.splitTextToSize(title.toUpperCase(), TEXT_W - 20);
    doc.text(titleLines, W/2, y, { align: 'center' });

    y += titleLines.length * 7 + 8;
    drawDivider(y);

    y += 15;

    // First ~500 chars on title page
    doc.setFontSize(9);
    setBody();
    doc.setTextColor(190, 180, 210);
    doc.setFont('helvetica', 'italic');
    const bodyPreview = body.substring(0, 400) + '...';
    const previewLines = doc.splitTextToSize(bodyPreview, TEXT_W);
    doc.text(previewLines, MARGIN, y);

    addPageNumber(pageNum++);

    // Full body page(s)
    doc.addPage();
    drawPageBg();

    y = MARGIN + 10;
    doc.setFontSize(7);
    setGold();
    doc.setFont('helvetica', 'bold');
    doc.text(`✦  ${title.toUpperCase()}  ✦`, W/2, y, { align: 'center' });

    y += 6;
    drawDivider(y);
    y += 12;

    doc.setFontSize(9.5);
    doc.setTextColor(200, 190, 220);
    doc.setFont('helvetica', 'normal');
    const bodyLines = doc.splitTextToSize(body, TEXT_W);

    for (let li = 0; li < bodyLines.length; li++) {
      if (y > H - 22) {
        addPageNumber(pageNum++);
        doc.addPage();
        drawPageBg();
        y = MARGIN + 10;
        doc.setFontSize(7);
        setGold();
        doc.setFont('helvetica', 'bold');
        doc.text(`${title.toUpperCase()}  (continued)`, W/2, y, { align: 'center' });
        y += 6;
        drawDivider(y);
        y += 12;
        doc.setFontSize(9.5);
        doc.setTextColor(200, 190, 220);
        doc.setFont('helvetica', 'normal');
      }
      doc.text(bodyLines[li], MARGIN, y);
      y += 5.5;
    }

    // Closing ornament
    y += 8;
    if (y < H - 30) {
      doc.setFontSize(9);
      setGold();
      doc.text('✦', W/2, y, { align: 'center' });
    }

    addPageNumber(pageNum++);
  }

  // ── CLOSING PAGE ──
  doc.addPage();
  drawPageBg();

  doc.setDrawColor(100, 75, 30);
  doc.setLineWidth(0.3);
  doc.circle(W/2, H/2, 40, 'S');
  doc.circle(W/2, H/2, 30, 'S');

  doc.setFontSize(14);
  setGoldLight();
  doc.setFont('helvetica', 'bold');
  doc.text('YOUR JOURNEY', W/2, H/2 - 10, { align: 'center' });

  doc.setFontSize(9);
  setGold();
  doc.setFont('helvetica', 'italic');
  doc.text('BEGINS NOW', W/2, H/2, { align: 'center' });

  doc.setFontSize(7);
  setMuted();
  doc.text(`✦  ${name.toUpperCase()}  ✦`, W/2, H/2 + 14, { align: 'center' });

  addPageNumber(pageNum);

  const totalPages = doc.getNumberOfPages();

  // Save
  const fileName = `CosmicBlueprint_${name.replace(/\s+/g,'_')}_${dob}.pdf`;
  doc.save(fileName);
}
</script>
</body>
</html>
